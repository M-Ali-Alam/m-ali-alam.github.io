---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const projects = await getCollection('research');

// Order projects specifically if needed (e.g. echo first, genobench second)
const sortedProjects = projects.sort((a, b) => {
  if (a.id === 'echo') return -1;
  if (b.id === 'echo') return 1;
  return 0;
});
---

<Layout>
  <!-- Hero Section -->
  <section class="py-section-gap grid grid-cols-1 md:grid-cols-12 gap-gutter items-center min-h-[716px]">
    <div class="md:col-span-8 md:col-start-1">
      <p class="font-label-caps text-label-caps text-slate-gray mb-4">PORTFOLIO & RESEARCH</p>
      <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-6">
        Muhammad Ali Alam — From Language Models to the Language of Life.
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant mb-10 max-w-3xl">
        M.Sc. Computer Science student at the University of Siegen, focusing on machine learning applications in biology and healthcare. My work spans audio-only depression detection to benchmarking linear-time genomic language models.
      </p>
      <div class="flex flex-wrap gap-4 items-center">
        <a class="bg-primary text-on-primary px-6 py-3 rounded hover:bg-ink-black transition-colors font-body-md text-body-md font-medium" href="#research">View Research</a>
        <a class="border border-outline text-primary px-6 py-3 rounded hover:bg-surface-container-low transition-colors font-body-md text-body-md font-medium" href="#cv">Download CV</a>
        <div class="flex gap-3 ml-2 border-l border-border-subtle pl-4 h-8 items-center">
          <a class="text-slate-gray hover:text-primary transition-colors text-sm font-medium" href="https://github.com/M-Ali-Alam" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a class="text-slate-gray hover:text-primary transition-colors text-sm font-medium" href="https://www.linkedin.com/in/muhammad-ali-alam/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>
    </div>
    
    <div class="hidden md:block md:col-span-4 md:col-start-9">
      <div class="bg-surface-container-low p-6 rounded border border-border-subtle">
        <h3 class="font-label-caps text-label-caps text-on-surface-variant mb-3 border-b border-border-subtle pb-2">CURRENT STATUS</h3>
        <ul class="space-y-3 font-mono-code text-mono-code text-primary">
          <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-slate-gray"></span> M.Sc. Student, Uni Siegen</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-slate-gray"></span> Pivoting to Comp. Genomics</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-slate-gray"></span> Seeking PhD Opportunities</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-section-gap border-t border-border-subtle" id="about">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
      <div class="md:col-span-4">
        <h2 class="font-headline-md text-headline-md text-primary mb-2">About Me</h2>
        <p class="font-label-caps text-label-caps text-slate-gray">MY JOURNEY</p>
      </div>
      <div class="md:col-span-8">
        <div class="space-y-6 font-body-md text-body-md text-on-surface-variant max-w-3xl">
          <p>
            MS Computer Science student at the University of Siegen, Germany, pivoting into computational biology.
          </p>
          <p>
            My work centers on applying machine learning to high-stakes, real-world problems. I lead the development of ECHO, an audio-based depression detection system evaluated on the DAIC-WOZ benchmark, building on prior multimodal depression-detection research, including a paper published at IEEE CODIT 2026 and another accepted at IEEE COINS 2026. I also developed and published GenoBench, an open-source Python benchmarking framework for genomic foundation models, supporting models such as HyenaDNA and DNABERT-2.
          </p>
          <p>
            Alongside my research, I mentor a cohort of approximately 45 students through an AI engineering certification program and founded AlamKitab, an online bookstore.
          </p>
          <p>
            I welcome connections with researchers and organizations working in genomic machine learning and computational biology.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Research Section -->
  <section class="py-section-gap border-t border-border-subtle" id="research">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
      <div class="md:col-span-4">
        <h2 class="font-headline-md text-headline-md text-primary mb-2">Research</h2>
        <p class="font-label-caps text-label-caps text-slate-gray">ACTIVE PROJECTS</p>
      </div>
      <div class="md:col-span-8 space-y-12">
        {sortedProjects.map((project) => (
          project.id === 'echo' ? (
            /* Custom card layout for ECHO matching Stitch Design */
            <div class="bg-surface p-8 rounded border border-border-subtle hover:border-primary/30 transition-all">
              <div class="flex items-start justify-between mb-4">
                <div>
                  <p class="font-label-caps text-label-caps text-secondary mb-2">{project.data.category}</p>
                  <h3 class="font-headline-sm text-headline-sm text-primary mb-3">{project.data.title}</h3>
                </div>
                <span class="bg-surface-container-high px-3 py-1 rounded text-xs font-mono-code">{project.data.status}</span>
              </div>
              <p class="font-body-md text-body-md text-on-surface-variant mb-6">
                {project.data.description}
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                  <h4 class="font-label-caps text-label-caps text-on-surface mb-2 border-b border-border-subtle pb-1">FEATURE EXTRACTION</h4>
                  <ul class="font-mono-code text-mono-code text-slate-gray space-y-1 text-sm">
                    <li>- eGeMAPS/openSMILE</li>
                    <li>- HuBERT-Large, WavLM-Large</li>
                    <li>- emotion2vec+, data2vec</li>
                    <li>- Custom WavLM-CLAP head</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-label-caps text-label-caps text-on-surface mb-2 border-b border-border-subtle pb-1">METHODOLOGY</h4>
                  <ul class="font-body-md text-body-md text-slate-gray space-y-1 text-sm">
                    <li>• Subject-disjoint k-fold CV</li>
                    <li>• Explicit speaker-leakage probe</li>
                    <li>• Macro-behavioral timing features</li>
                  </ul>
                </div>
              </div>
              <a class="inline-flex items-center text-primary font-medium hover:text-secondary transition-colors font-body-md" href={`/research/${project.id}`}>
                Read Detailed Methodology <span class="material-symbols-outlined ml-1 text-sm">arrow_forward</span>
              </a>
            </div>
          ) : (
            /* Custom card layout for GenoBench matching Stitch Design */
            <div class="border-l-2 border-primary pl-6 py-2 hover:border-secondary transition-colors">
              <p class="font-label-caps text-label-caps text-secondary mb-2">{project.data.category}</p>
              <h3 class="font-headline-sm text-headline-sm text-primary mb-3">{project.data.title}</h3>
              <p class="font-body-md text-body-md text-on-surface-variant mb-4 max-w-2xl">
                {project.data.description}
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                {project.data.tags?.map((tag) => (
                  <span class="bg-surface-container-low px-2 py-1 rounded text-xs font-mono-code text-slate-gray">{tag}</span>
                ))}
              </div>
              <div class="flex gap-4">
                <a class="inline-flex items-center text-primary font-medium hover:text-secondary transition-colors font-body-md" href={`/research/${project.id}`}>
                  Read Project Details <span class="material-symbols-outlined ml-1 text-sm">arrow_forward</span>
                </a>
                <a class="inline-flex items-center text-secondary font-medium hover:text-primary transition-colors font-body-md" href="https://github.com/M-Ali-Alam/GenoBench" target="_blank" rel="noopener noreferrer">
                  View Repository <span class="material-symbols-outlined ml-1 text-sm">arrow_outward</span>
                </a>
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- Experience Section -->
  <section class="py-section-gap border-t border-border-subtle" id="experience">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
      <div class="md:col-span-4">
        <h2 class="font-headline-md text-headline-md text-primary mb-2">Experience</h2>
        <p class="font-label-caps text-label-caps text-slate-gray">ROLES & MENTORSHIP</p>
      </div>
      <div class="md:col-span-8 space-y-8">
        <!-- Experience Item 1 -->
        <div class="border-b border-border-subtle pb-6 last:border-none last:pb-0">
          <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-2">
            <div>
              <h3 class="font-headline-sm text-headline-sm text-primary">AuratTech</h3>
              <p class="text-on-surface-variant text-sm font-medium">Mentorship &amp; Education Lead</p>
            </div>
            <span class="text-slate-gray font-mono-code text-sm">2025 - Present</span>
          </div>
          <p class="font-body-md text-body-md text-on-surface-variant mb-3">
            Guiding a cohort of approximately 45 students through DataCamp's "AI Engineer for Data Scientists Associate" track. Leading twice-weekly live sessions and designing educational pipelines.
          </p>
          <ul class="list-disc pl-5 font-body-md text-body-md text-slate-gray space-y-1">
            <li>Built an async pre-session review process using custom forms to identify student blocks beforehand.</li>
            <li>Run targeted live triage sessions focused specifically on clearing conceptual blocks and debugging code live.</li>
          </ul>
        </div>

        <!-- Experience Item 2 -->
        <div class="border-b border-border-subtle pb-6 last:border-none last:pb-0">
          <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-2">
            <div>
              <h3 class="font-headline-sm text-headline-sm text-primary">CreditBook</h3>
              <p class="text-on-surface-variant text-sm font-medium">Software Engineer</p>
            </div>
            <span class="text-slate-gray font-mono-code text-sm">2023 - 2024</span>
          </div>
          <p class="font-body-md text-body-md text-on-surface-variant">
            Full-stack engineering focused on financial ledger APIs. Architected robust, high-performance backends and interactive frontend dashboards.
          </p>
          <div class="flex flex-wrap gap-2 mt-3">
            <span class="bg-surface-container-low px-2 py-0.5 rounded text-xs font-mono-code text-slate-gray">NestJS</span>
            <span class="bg-surface-container-low px-2 py-0.5 rounded text-xs font-mono-code text-slate-gray">ReactJS</span>
            <span class="bg-surface-container-low px-2 py-0.5 rounded text-xs font-mono-code text-slate-gray">AWS Lambda</span>
            <span class="bg-surface-container-low px-2 py-0.5 rounded text-xs font-mono-code text-slate-gray">TypeScript</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="py-section-gap border-t border-border-subtle" id="skills">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
      <div class="md:col-span-4">
        <h2 class="font-headline-md text-headline-md text-primary mb-2">Skills</h2>
        <p class="font-label-caps text-label-caps text-slate-gray">TECHNICAL SKILLS</p>
      </div>
      <div class="md:col-span-8 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="font-label-caps text-label-caps text-primary border-b border-border-subtle pb-2 mb-4">LANGUAGES &amp; ML</h3>
            <div class="flex flex-wrap gap-2">
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">Python</span>
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">PyTorch</span>
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">R</span>
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">HuggingFace</span>
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">SQL</span>
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">Bash</span>
            </div>
          </div>
          <div>
            <h3 class="font-label-caps text-label-caps text-primary border-b border-border-subtle pb-2 mb-4">INFRASTRUCTURE &amp; TOOLS</h3>
            <div class="flex flex-wrap gap-2">
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">SLURM (HPC)</span>
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">Docker</span>
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">AWS</span>
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">TypeScript</span>
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">React</span>
              <span class="bg-surface-container px-3 py-1 rounded text-sm font-mono-code">NestJS</span>
            </div>
          </div>
        </div>

        <div>
          <h3 class="font-label-caps text-label-caps text-primary border-b border-border-subtle pb-2 mb-4">LANGUAGES</h3>
          <div class="space-y-2 font-body-md text-body-md text-slate-gray">
            <p><strong>English</strong> — C1 (Professional / Academic Fluency)</p>
            <p><strong>Urdu / Hindi</strong> — Native</p>
            <p><strong>German</strong> — B1 (Intermediate)</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Side Projects Section -->
  <section class="py-section-gap border-t border-border-subtle" id="side-projects">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
      <div class="md:col-span-4">
        <h2 class="font-headline-md text-headline-md text-primary mb-2">Side Projects</h2>
        <p class="font-label-caps text-label-caps text-slate-gray">INDEPENDENT SHIPPING</p>
      </div>
      <div class="md:col-span-8">
        <div class="bg-surface p-6 rounded border border-border-subtle hover:border-primary/20 transition-all max-w-2xl">
          <div class="flex justify-between items-start mb-2">
            <h3 class="font-headline-sm text-headline-sm text-primary">AlamKitab</h3>
            <span class="text-slate-gray font-mono-code text-xs">Live</span>
          </div>
          <p class="font-body-md text-body-md text-on-surface-variant mb-4">
            An online bookstore built and maintained independently. Ships books across regions, managing inventory and payment integrations.
          </p>
          <a class="inline-flex items-center text-primary font-medium hover:text-secondary transition-colors font-body-md text-sm" href="https://alamkitab.com" target="_blank" rel="noopener noreferrer">
            Visit AlamKitab <span class="material-symbols-outlined ml-1 text-sm">arrow_outward</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CV / Contact Section -->
  <section class="py-section-gap border-t border-border-subtle" id="cv">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
      <div class="md:col-span-4">
        <h2 class="font-headline-md text-headline-md text-primary mb-2">CV &amp; Contact</h2>
        <p class="font-label-caps text-label-caps text-slate-gray">GET IN TOUCH</p>
      </div>
      <div class="md:col-span-8 space-y-6">
        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl">
          Currently exploring PhD positions in computational biology — if that overlaps with your work, I'd like to hear from you.
        </p>
        <div class="flex flex-wrap gap-4">
          <a class="bg-primary text-on-primary px-6 py-3 rounded hover:bg-ink-black transition-colors font-body-md text-body-md font-medium inline-flex items-center" href="/Muhammad_Ali_Alam_CV.pdf" download>
            <span class="material-symbols-outlined mr-2">download</span> Download CV (PDF)
          </a>
          <a class="border border-outline text-primary px-6 py-3 rounded hover:bg-surface-container-low transition-colors font-body-md text-body-md font-medium inline-flex items-center" href="mailto:email@example.com">
            <span class="material-symbols-outlined mr-2">mail</span> Send Email
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
